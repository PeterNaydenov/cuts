{
  "name": "@peter.naydenov/cuts",
  "description": "SPA scene manager",
  "version": "2.0.3",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "./src/main.js",
  "type": "module",
  "types": "./types/main.d.ts",
  "exports": {
    ".": {
      "import": "./src/main.js",
      "require": "./dist/cuts.cjs",
      "default": "./src/main.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "rollup -c",
    "postbuild": "tsc -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "cover": "vitest run --coverage"
  },
  "devDependencies": {
    "@peter.naydenov/visual-controller-for-vue3": "^2.3.1",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "rollup": "^4.60.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue": "^3.5.35"
  },
  "dependencies": {
    "@peter.naydenov/log": "^1.1.1",
    "@peter.naydenov/shortcuts": "^4.0.2",
    "ask-for-promise": "^3.1.1"
  },
  "keywords": [
    "script",
    "visual",
    "state",
    "manager"
  ]
}
